# Copy this file to .env and fill in the values.

# Your Postgres connection string.
#
# Option A — local Postgres (after `createdb health_records`):
DATABASE_URL=postgres://localhost:5432/health_records
#
# Option B — Supabase (hosted Postgres, no local install needed). In the Supabase
# dashboard: Project → Connect → "Connection string" → URI. Use the "Session"
# pooler URI and put your DB password in it. SSL is turned on automatically for
# non-local hosts. Example shape:
# DATABASE_URL=postgresql://postgres.abcdefgh:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# Your Claude API key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Email delivery for real sign-in codes (optional locally — without it, dev mode
# prints the code in the server terminal).
#
# Option A — Brevo HTTPS API (works everywhere, incl. hosts that block SMTP,
# e.g. Render's free tier). Free key at https://app.brevo.com → SMTP & API.
# BREVO_API_KEY=xkeysib-...
# EMAIL_FROM=you@gmail.com
#
# Option B — classic SMTP (Gmail App Password from
# https://myaccount.google.com/apppasswords; requires 2-Step Verification).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-letter-app-password
# SMTP_FROM=Health Records <you@gmail.com>

# Optional overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# PORT=3001
